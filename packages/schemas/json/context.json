{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "webdriver://context",
  "definitions": {
    "WindowHandleResult": {
      "type": "object",
      "properties": {
        "handle": { "type": "string" }
      },
      "required": ["handle"],
      "additionalProperties": false
    },
    "WindowHandlesResult": {
      "type": "object",
      "properties": {
        "handles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["handles"],
      "additionalProperties": false
    },
    "SwitchToWindowParams": {
      "type": "object",
      "properties": {
        "handle": { "type": "string" }
      },
      "required": ["handle"],
      "additionalProperties": false
    },
    "NewWindowParams": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["tab", "window"]
        }
      },
      "additionalProperties": false
    },
    "NewWindowResult": {
      "type": "object",
      "properties": {
        "handle": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["tab", "window"]
        }
      },
      "required": ["handle", "type"],
      "additionalProperties": false
    },
    "SwitchToFrameParams": {
      "type": "object",
      "properties": {
        "id": {}
      },
      "required": ["id"],
      "additionalProperties": false
    }
  }
}
