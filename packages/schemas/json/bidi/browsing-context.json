{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "webdriver-bidi://browsing-context",
	"definitions": {
		"BrowsingContext": {
			"type": "string",
			"description": "Opaque browsing context ID"
		},
		"Navigation": {
			"type": "string",
			"description": "Opaque navigation ID"
		},
		"ReadinessState": {
			"type": "string",
			"enum": ["none", "interactive", "complete"]
		},
		"CreateType": {
			"type": "string",
			"enum": ["tab", "window"]
		},
		"CreateParams": {
			"type": "object",
			"properties": {
				"type": { "$ref": "#/definitions/CreateType" },
				"referenceContext": { "$ref": "#/definitions/BrowsingContext" },
				"background": { "type": "boolean" },
				"userContext": { "type": "string" }
			},
			"required": ["type"],
			"additionalProperties": false
		},
		"CreateResult": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" }
			},
			"required": ["context"],
			"additionalProperties": false
		},
		"CloseParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"promptUnload": { "type": "boolean" }
			},
			"required": ["context"],
			"additionalProperties": false
		},
		"ActivateParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" }
			},
			"required": ["context"],
			"additionalProperties": false
		},
		"NavigateParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"url": { "type": "string" },
				"wait": { "$ref": "#/definitions/ReadinessState" }
			},
			"required": ["context", "url"],
			"additionalProperties": false
		},
		"NavigateResult": {
			"type": "object",
			"properties": {
				"navigation": { "$ref": "#/definitions/Navigation" },
				"url": { "type": "string" }
			},
			"required": ["url"],
			"additionalProperties": false
		},
		"ReloadParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"ignoreCache": { "type": "boolean" },
				"wait": { "$ref": "#/definitions/ReadinessState" }
			},
			"required": ["context"],
			"additionalProperties": false
		},
		"TraverseHistoryParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"delta": { "type": "integer" }
			},
			"required": ["context", "delta"],
			"additionalProperties": false
		},
		"GetTreeParams": {
			"type": "object",
			"properties": {
				"maxDepth": { "type": "integer" },
				"root": { "$ref": "#/definitions/BrowsingContext" }
			},
			"additionalProperties": false
		},
		"InfoListResult": {
			"type": "object",
			"properties": {
				"contexts": {
					"type": "array",
					"items": { "$ref": "#/definitions/Info" }
				}
			},
			"required": ["contexts"],
			"additionalProperties": false
		},
		"Info": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"url": { "type": "string" },
				"parent": { "$ref": "#/definitions/BrowsingContext" },
				"children": {
					"type": "array",
					"items": { "$ref": "#/definitions/Info" }
				},
				"userContext": { "type": "string" },
				"originalOpener": { "$ref": "#/definitions/BrowsingContext" }
			},
			"required": ["context", "url", "children"],
			"additionalProperties": false
		},
		"SetViewportParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"viewport": {
					"type": "object",
					"properties": {
						"width": { "type": "integer" },
						"height": { "type": "integer" }
					},
					"required": ["width", "height"],
					"additionalProperties": false
				},
				"devicePixelRatio": { "type": "number" }
			},
			"required": ["context"],
			"additionalProperties": false
		},
		"PrintParams": {
			"type": "object",
			"properties": {
				"context": { "$ref": "#/definitions/BrowsingContext" },
				"background": { "type": "boolean" },
				"orientation": {
					"type": "string",
					"enum": ["portrait", "landscape"]
				},
				"page": {
					"type": "object",
					"properties": {
						"width": { "type": "number" },
						"height": { "type": "number" }
					},
					"additionalProperties": false
				},
				"margin": {
					"type": "object",
					"properties": {
						"top": { "type": "number" },
						"bottom": { "type": "number" },
						"left": { "type": "number" },
						"right": { "type": "number" }
					},
					"additionalProperties": false
				},
				"pageRanges": {
					"type": "array",
					"items": {}
				},
				"scale": { "type": "number" },
				"shrinkToFit": { "type": "boolean" }
			},
			"required": ["context"],
			"additionalProperties": false
		},
		"PrintResult": {
			"type": "object",
			"properties": {
				"data": { "type": "string" }
			},
			"required": ["data"],
			"additionalProperties": false
		}
	}
}
