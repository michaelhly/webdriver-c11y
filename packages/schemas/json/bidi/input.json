{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "webdriver-bidi://input",
  "definitions": {
    "SourceActionType": {
      "type": "string",
      "enum": ["none", "key", "pointer", "wheel"]
    },
    "PointerType": {
      "type": "string",
      "enum": ["mouse", "pen", "touch"]
    },
    "KeyAction": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["keyDown", "keyUp", "pause"]
        },
        "value": { "type": "string" },
        "duration": { "type": "integer" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "PointerAction": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["pointerDown", "pointerUp", "pointerMove", "pause"]
        },
        "button": { "type": "integer" },
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "duration": { "type": "integer" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "pressure": { "type": "number" },
        "tangentialPressure": { "type": "number" },
        "twist": { "type": "integer" },
        "altitudeAngle": { "type": "number" },
        "azimuthAngle": { "type": "number" },
        "origin": {}
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "WheelAction": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["scroll", "pause"]
        },
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "deltaX": { "type": "integer" },
        "deltaY": { "type": "integer" },
        "duration": { "type": "integer" },
        "origin": {}
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "SourceActions": {
      "type": "object",
      "properties": {
        "type": { "$ref": "#/definitions/SourceActionType" },
        "id": { "type": "string" },
        "parameters": {
          "type": "object",
          "properties": {
            "pointerType": { "$ref": "#/definitions/PointerType" }
          },
          "additionalProperties": false
        },
        "actions": {
          "type": "array",
          "items": {}
        }
      },
      "required": ["type", "id", "actions"],
      "additionalProperties": false
    },
    "PerformActionsParams": {
      "type": "object",
      "properties": {
        "context": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/SourceActions" }
        }
      },
      "required": ["context", "actions"],
      "additionalProperties": false
    },
    "ReleaseActionsParams": {
      "type": "object",
      "properties": {
        "context": { "type": "string" }
      },
      "required": ["context"],
      "additionalProperties": false
    },
    "SetFilesParams": {
      "type": "object",
      "properties": {
        "context": { "type": "string" },
        "element": {},
        "files": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["context", "element", "files"],
      "additionalProperties": false
    }
  }
}
