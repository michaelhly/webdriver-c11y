{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "webdriver://session",
	"definitions": {
		"ProxyConfiguration": {
			"type": "object",
			"properties": {
				"proxyType": {
					"type": "string",
					"enum": ["pac", "direct", "autodetect", "system", "manual"]
				},
				"proxyAutoconfigUrl": { "type": "string" },
				"ftpProxy": { "type": "string" },
				"httpProxy": { "type": "string" },
				"noProxy": {
					"type": "array",
					"items": { "type": "string" }
				},
				"sslProxy": { "type": "string" },
				"socksProxy": { "type": "string" },
				"socksVersion": {
					"type": "integer",
					"minimum": 0,
					"maximum": 255
				}
			},
			"additionalProperties": false
		},
		"Capabilities": {
			"type": "object",
			"properties": {
				"browserName": { "type": "string" },
				"browserVersion": { "type": "string" },
				"platformName": { "type": "string" },
				"acceptInsecureCerts": { "type": "boolean" },
				"pageLoadStrategy": {
					"type": "string",
					"enum": ["none", "eager", "normal"]
				},
				"proxy": { "$ref": "#/definitions/ProxyConfiguration" },
				"timeouts": { "$ref": "#/definitions/Timeouts" },
				"strictFileInteractability": { "type": "boolean" },
				"unhandledPromptBehavior": {
					"type": "string",
					"enum": [
						"dismiss",
						"accept",
						"dismiss and notify",
						"accept and notify",
						"ignore"
					]
				},
				"userAgent": { "type": "string" }
			},
			"additionalProperties": true
		},
		"CapabilitiesRequest": {
			"type": "object",
			"properties": {
				"alwaysMatch": { "$ref": "#/definitions/Capabilities" },
				"firstMatch": {
					"type": "array",
					"items": { "$ref": "#/definitions/Capabilities" },
					"minItems": 1
				}
			},
			"additionalProperties": false
		},
		"NewSessionParams": {
			"type": "object",
			"properties": {
				"capabilities": { "$ref": "#/definitions/CapabilitiesRequest" }
			},
			"additionalProperties": false
		},
		"NewSessionResult": {
			"type": "object",
			"properties": {
				"sessionId": { "type": "string" },
				"capabilities": { "$ref": "#/definitions/Capabilities" }
			},
			"required": ["sessionId", "capabilities"],
			"additionalProperties": false
		},
		"StatusResult": {
			"type": "object",
			"properties": {
				"ready": { "type": "boolean" },
				"message": { "type": "string" }
			},
			"required": ["ready", "message"],
			"additionalProperties": false
		},
		"Timeouts": {
			"type": "object",
			"properties": {
				"script": { "type": ["integer", "null"] },
				"pageLoad": { "type": "integer" },
				"implicit": { "type": "integer" }
			},
			"additionalProperties": false
		}
	}
}
