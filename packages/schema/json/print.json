{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "webdriver://print",
	"definitions": {
		"PrintParams": {
			"type": "object",
			"properties": {
				"orientation": {
					"type": "string",
					"enum": ["portrait", "landscape"]
				},
				"scale": { "type": "number" },
				"background": { "type": "boolean" },
				"page": {
					"type": "object",
					"properties": {
						"width": { "type": "number" },
						"height": { "type": "number" }
					},
					"additionalProperties": false
				},
				"margin": {
					"type": "object",
					"properties": {
						"top": { "type": "number" },
						"bottom": { "type": "number" },
						"left": { "type": "number" },
						"right": { "type": "number" }
					},
					"additionalProperties": false
				},
				"pageRanges": {
					"type": "array",
					"items": {}
				},
				"shrinkToFit": { "type": "boolean" }
			},
			"additionalProperties": false
		},
		"PrintResult": {
			"type": "object",
			"properties": {
				"data": { "type": "string" }
			},
			"required": ["data"],
			"additionalProperties": false
		}
	}
}
